---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<Layout>

<Fragment slot="head">
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</Fragment>

<!-- ══ CURSOR ══════════════════════════════════════ -->
<div class="cursor" id="cursor" aria-hidden="true">
  <div class="cursor__dot"></div>
  <div class="cursor__ring"></div>
</div>

<!-- ══ NAV ════════════════════════════════════════ -->
<header class="nav" id="nav">
  <div class="nav__inner">
    <a href="#" class="nav__logo" data-magnetic>
      <img src="/ChatGPT_Image_May_1__2026__04_24_08_PM-removebg-preview.png" alt="K3 Creative Works logo" height="48" aria-hidden="true" />
      <span>K3 <em>Creative Works</em></span>
    </a>
    <nav class="nav__links">
      <a href="#services" class="nav__link" data-magnetic>Services</a>
      <a href="#contact" class="nav__link" data-magnetic>Contact</a>
      <a href="#contact" class="nav__cta" data-magnetic>Start a Project</a>
    </nav>
    <button class="nav__burger" id="burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobile-menu">
  <a href="#services" class="mm-link">Services</a>
  <a href="#contact" class="mm-link">Contact</a>
  <a href="#contact" class="mm-link mm-link--cta">Start a Project →</a>
</div>

<main>

<!-- ══ HERO ═══════════════════════════════════════ -->
<section class="hero" id="hero">
  <canvas class="hero__canvas" id="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero__glow" id="hero-glow" aria-hidden="true"></div>

  <div class="hero__left">
    <p class="hero__pre">Digital Consulting · Web Development · Custom Apps</p>

    <h1 class="hero__title">
      <span class="hero__line">Build smarter.</span>
      <span class="hero__line hero__line--accent">Grow faster.</span>
    </h1>

    <p class="hero__sub">
      K3 Creative Works engineers digital products that move your business forward —
      from strategy to launch and beyond.
    </p>

    <div class="hero__actions">
      <a href="#services" class="btn-hero btn-hero--primary" data-magnetic>
        <span>Explore Services</span>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M4 9H14M14 9L10 5M14 9L10 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#contact" class="btn-hero btn-hero--ghost" data-magnetic>Get in Touch</a>
    </div>
  </div>

  <!-- Interactive right panel -->
  <div class="hero__right" id="hero-right" aria-hidden="true">
    <canvas class="hero__scene" id="hero-scene"></canvas>
    <!-- Floating labels that drift on mouse -->
    <div class="hero__label" data-depth="0.06" style="top:12%;left:62%">React</div>
    <div class="hero__label" data-depth="0.10" style="top:20%;left:82%">Node.js</div>
    <div class="hero__label" data-depth="0.04" style="top:72%;left:60%">TypeScript</div>
    <div class="hero__label" data-depth="0.08" style="top:78%;left:84%">Astro</div>
    <div class="hero__label" data-depth="0.12" style="top:44%;left:88%">PostgreSQL</div>
    <div class="hero__label hero__label--dim" data-depth="0.05" style="top:8%;left:72%">API Design</div>
    <div class="hero__label hero__label--dim" data-depth="0.09" style="top:88%;left:72%">Cloud</div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <div class="hero__scroll-wheel"></div>
  </div>
</section>

<!-- ══ SERVICES ════════════════════════════════════ -->
<section class="services" id="services">
  <div class="services__header js-reveal">
    <span class="eyebrow">What We Do</span>
    <h2>Three disciplines.<br/><em>One partner.</em></h2>
  </div>

  <div class="cards" id="cards">

    <div class="card js-reveal" data-tilt data-index="0">
      <div class="card__shine" aria-hidden="true"></div>
      <div class="card__num" aria-hidden="true">01</div>
      <div class="card__icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <path d="M3 7C3 5.895 3.895 5 5 5H23C24.105 5 25 5.895 25 7V19C25 20.105 24.105 21 23 21H5C3.895 21 3 20.105 3 19V7Z" stroke="currentColor" stroke-width="1.75"/>
          <path d="M9 25H19M14 21V25" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          <path d="M8 13L11 10L14 13L20 7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3>Digital Consulting</h3>
      <p>Strategy and roadmaps that cut through complexity. We audit your digital landscape and give you a clear, actionable plan to grow.</p>
      <ul class="card__tags">
        <li>Digital Transformation</li>
        <li>Tech Audits</li>
        <li>Growth Strategy</li>
        <li>Process Automation</li>
      </ul>
      <a href="#contact" class="card__cta" data-magnetic>
        Let's Talk
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="card card--featured js-reveal" data-tilt data-index="1">
      <div class="card__shine" aria-hidden="true"></div>
      <div class="card__badge">Most Popular</div>
      <div class="card__num" aria-hidden="true">02</div>
      <div class="card__icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <rect x="3" y="5" width="22" height="18" rx="2" stroke="currentColor" stroke-width="1.75"/>
          <path d="M3 10H25" stroke="currentColor" stroke-width="1.75"/>
          <circle cx="7.5" cy="7.5" r="1" fill="currentColor"/>
          <circle cx="11" cy="7.5" r="1" fill="currentColor"/>
          <path d="M9 15L12 18L9 21M16 21H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3>Web Development</h3>
      <p>Performance-first websites built with modern frameworks. Pixel-perfect, fast, and optimised for conversion from day one.</p>
      <ul class="card__tags">
        <li>Marketing Sites</li>
        <li>E-Commerce</li>
        <li>CMS Platforms</li>
        <li>Performance Audits</li>
      </ul>
      <a href="#contact" class="card__cta" data-magnetic>
        Let's Talk
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="card js-reveal" data-tilt data-index="2">
      <div class="card__shine" aria-hidden="true"></div>
      <div class="card__num" aria-hidden="true">03</div>
      <div class="card__icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <path d="M10 3H7C4.791 3 3 4.791 3 7V10M18 3H21C23.209 3 25 4.791 25 7V10M10 25H7C4.791 25 3 23.209 3 21V18M18 25H21C23.209 25 25 23.209 25 21V18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          <rect x="9" y="9" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.75"/>
          <path d="M11.5 14L13 15.5L16.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3>Custom Applications</h3>
      <p>Purpose-built software for your exact workflows — internal tools, SaaS products, APIs, and mobile apps engineered to scale.</p>
      <ul class="card__tags">
        <li>SaaS Products</li>
        <li>Internal Tools</li>
        <li>API Design</li>
        <li>Mobile Apps</li>
      </ul>
      <a href="#contact" class="card__cta" data-magnetic>
        Let's Talk
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<!-- ══ CONTACT ═════════════════════════════════════ -->
<section class="contact" id="contact">
  <div class="contact__inner">
    <div class="contact__left js-reveal">
      <span class="eyebrow">Get In Touch</span>
      <h2>Let's build<br/><em>something great.</em></h2>
      <p>No pitch decks, no fluff — just a real conversation about what you need. We'll get back to you within one business day.</p>
      <a href="mailto:hello@k3creativeworks.com" class="contact__email" data-magnetic>
        hello@k3creativeworks.com
      </a>
    </div>
    <div class="contact__form-wrap js-reveal">
      <form class="contact__form" id="contact-form" novalidate>
        <div class="field-row">
          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Jane Smith" required autocomplete="name"/>
            <span class="field__border"></span>
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="jane@company.com" required autocomplete="email"/>
            <span class="field__border"></span>
          </div>
        </div>
        <div class="field">
          <label for="service">Service</label>
          <select id="service" name="service" required>
            <option value="" disabled selected>What do you need?</option>
            <option value="consulting">Digital Consulting</option>
            <option value="web">Web Development</option>
            <option value="apps">Custom Applications</option>
            <option value="other">Not sure — let's talk</option>
          </select>
          <span class="field__border"></span>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="4" placeholder="Tell us about your project…" required></textarea>
          <span class="field__border"></span>
        </div>
        <!-- Honeypot — hidden from real users, bots fill it in -->
        <div class="hp-field" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <!-- Cloudflare Turnstile -->
        <div class="cf-turnstile" data-sitekey={siteKey} data-theme="light" style="margin-bottom:20px"></div>

        <button type="submit" class="submit-btn" data-magnetic id="submit-btn">
          <span class="submit-btn__text">Send Message</span>
          <span class="submit-btn__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M4 9H14M14 9L10 5M14 9L10 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="submit-btn__loader" aria-hidden="true"></span>
        </button>
      </form>
      <p class="form-error" id="form-error" hidden></p>
      <div class="contact__success" id="form-success" hidden>
        <div class="success__icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="18" stroke="#4a7cb5" stroke-width="2"/>
            <path d="M12 20L18 26L28 14" stroke="#1a3a5c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Message sent!</h3>
        <p>We'll be in touch within one business day.</p>
      </div>
    </div>
  </div>
</section>

</main>

<!-- ══ FOOTER ══════════════════════════════════════ -->
<footer class="footer">
  <div class="footer__inner">
    <a href="#" class="footer__logo">
      <img src="/ChatGPT_Image_May_1__2026__04_24_08_PM-removebg-preview.png" alt="K3 Creative Works logo" height="32" aria-hidden="true" />
      <span>K3 Creative Works LLC</span>
    </a>
    <p class="footer__copy">&copy; <span id="yr"></span> K3 Creative Works LLC</p>
  </div>
</footer>

</Layout>

<style>
/* ── Honeypot ─────────────────────────────────── */
.hp-field {
  position: absolute;
  left: -9999px;
  opacity: 0;
  pointer-events: none;
  height: 0;
  overflow: hidden;
}

/* ── Cursor ───────────────────────────────────── */
.cursor {
  pointer-events: none;
  position: fixed; top: 0; left: 0;
  z-index: 9999;
  mix-blend-mode: difference;
}

.cursor__dot {
  position: absolute;
  width: 8px; height: 8px; border-radius: 50%;
  background: white;
  transform: translate(-50%, -50%);
  transition: width .15s, height .15s;
}

.cursor__ring {
  position: absolute;
  width: 36px; height: 36px; border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,.7);
  transform: translate(-50%, -50%);
  transition: width .35s cubic-bezier(.25,.46,.45,.94),
              height .35s cubic-bezier(.25,.46,.45,.94),
              border-color .2s;
}

body.cursor-hover .cursor__ring { width: 64px; height: 64px; border-color: rgba(255,255,255,.3); }
body.cursor-click .cursor__dot  { width: 12px; height: 12px; }

@media (hover: none) { .cursor { display: none; } }

/* ── Nav ──────────────────────────────────────── */
.nav {
  position: fixed; inset: 0 0 auto 0; z-index: 200;
  height: 68px; padding: 0 48px;
  display: flex; align-items: center;
  background: transparent;
  transition: background .4s, backdrop-filter .4s;
}

.nav.scrolled {
  background: rgba(10,22,36,.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,255,255,.06);
}

.nav__inner {
  width: 100%; display: flex;
  align-items: center; justify-content: space-between;
}

.nav__logo {
  display: flex; align-items: center; gap: 10px;
  font-size: .95rem; font-weight: 700;
  color: white; text-decoration: none;
}

.nav__logo em { color: var(--silver-400); font-style: normal; font-weight: 400; }

.nav__links { display: flex; align-items: center; gap: 32px; }

.nav__link {
  color: var(--silver-400); font-size: .875rem; font-weight: 500;
  text-decoration: none; position: relative; transition: color .2s;
}

.nav__link::after {
  content: ''; position: absolute;
  bottom: -3px; left: 0; right: 0;
  height: 1px; background: var(--navy-300);
  transform: scaleX(0); transform-origin: left;
  transition: transform .3s cubic-bezier(.4,0,.2,1);
}

.nav__link:hover { color: white; }
.nav__link:hover::after { transform: scaleX(1); }

.nav__cta {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 9px 20px; background: var(--navy-700);
  color: white; border-radius: 8px;
  font-size: .875rem; font-weight: 600;
  text-decoration: none;
  border: 1px solid rgba(255,255,255,.1);
  transition: background .2s, transform .2s, box-shadow .2s;
}

.nav__cta:hover {
  background: var(--navy-600);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(26,58,92,.5);
}

.nav__burger {
  display: none; flex-direction: column; gap: 6px;
  padding: 8px; background: none; border: none; cursor: pointer;
}

.nav__burger span {
  display: block; width: 22px; height: 2px;
  background: var(--silver-300); border-radius: 2px;
  transition: all .3s;
}

.nav__burger[aria-expanded="true"] span:first-child { transform: translateY(8px) rotate(45deg); }
.nav__burger[aria-expanded="true"] span:last-child  { transform: translateY(-8px) rotate(-45deg); }

.mobile-menu {
  position: fixed; top: 68px; inset-inline: 0;
  background: var(--navy-900);
  border-bottom: 1px solid rgba(255,255,255,.07);
  z-index: 199;
  display: flex; flex-direction: column;
  padding: 16px 24px 24px; gap: 4px;
  transform: translateY(-100%); opacity: 0;
  transition: transform .4s cubic-bezier(.4,0,.2,1), opacity .3s;
  pointer-events: none;
}

.mobile-menu.open { transform: translateY(0); opacity: 1; pointer-events: all; }

.mm-link {
  display: block; padding: 14px 0;
  color: var(--silver-300); font-size: 1rem; font-weight: 500;
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,.06);
  transition: color .2s;
}

.mm-link:hover { color: white; }

.mm-link--cta {
  margin-top: 12px; padding: 14px 20px;
  background: var(--navy-700); color: white;
  border-radius: 8px; text-align: center; border: none; font-weight: 600;
}

/* ── Hero ─────────────────────────────────────── */
.hero {
  position: relative; min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  background: linear-gradient(140deg, #070f1a 0%, #0d1f33 45%, #0f2540 100%);
  overflow: hidden;
  padding: 0 6vw 0 10vw;
}

.hero__canvas {
  position: absolute; inset: 0;
  width: 100%; height: 100%; pointer-events: none;
}

.hero__glow {
  position: absolute;
  width: 700px; height: 700px; border-radius: 50%;
  background: radial-gradient(circle, rgba(42,90,147,.25) 0%, transparent 70%);
  pointer-events: none;
  transform: translate(-50%, -50%);
  transition: left .1s ease-out, top .1s ease-out;
}

.hero__left { position: relative; z-index: 2; }

/* Right panel */
.hero__right {
  position: relative;
  height: 100vh;
  z-index: 2;
  overflow: hidden;
}

.hero__scene {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
}

/* Floating tech labels */
.hero__label {
  position: absolute;
  padding: 6px 14px;
  background: rgba(26,58,92,.55);
  border: 1px solid rgba(122,170,212,.25);
  border-radius: 100px;
  font-size: .72rem; font-weight: 700;
  letter-spacing: .08em; text-transform: uppercase;
  color: var(--navy-300);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  white-space: nowrap;
  transition: transform .05s linear, opacity .3s;
  pointer-events: none;
  will-change: transform;
}

.hero__label--dim {
  opacity: .45;
  font-size: .65rem;
}

/* ── Old .hero__content alias ─ keep for hero left */
.hero__content { position: relative; z-index: 2; max-width: 720px; }

.hero__pre {
  font-size: .72rem; font-weight: 700;
  letter-spacing: .12em; text-transform: uppercase;
  color: var(--navy-300); margin-bottom: 28px;
  opacity: 0; animation: fadeUp .8s .2s ease forwards;
}

.hero__title { display: flex; flex-direction: column; margin-bottom: 28px; line-height: 1.05; }

.hero__line {
  display: block;
  font-size: clamp(3.5rem, 7vw, 6rem);
  font-weight: 800; color: white;
  letter-spacing: -.03em;
  opacity: 0; animation: fadeUp .8s ease forwards;
}

.hero__line:nth-child(1) { animation-delay: .3s; }
.hero__line:nth-child(2) { animation-delay: .45s; }

.hero__line--accent {
  background: linear-gradient(135deg, var(--navy-300) 0%, var(--silver-300) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

.hero__sub {
  font-size: 1.125rem; color: var(--silver-500);
  line-height: 1.8; max-width: 480px; margin-bottom: 44px;
  opacity: 0; animation: fadeUp .8s .6s ease forwards;
}

.hero__actions {
  display: flex; gap: 16px; flex-wrap: wrap;
  opacity: 0; animation: fadeUp .8s .75s ease forwards;
}

.btn-hero {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 15px 32px; border-radius: 10px;
  font-size: .95rem; font-weight: 600;
  text-decoration: none; position: relative; overflow: hidden;
  transition: transform .2s, box-shadow .2s;
}

.btn-hero::before {
  content: ''; position: absolute; inset: 0;
  background: rgba(255,255,255,.08);
  transform: scaleX(0); transform-origin: left;
  transition: transform .35s cubic-bezier(.4,0,.2,1);
}

.btn-hero:hover::before { transform: scaleX(1); }
.btn-hero:hover { transform: translateY(-3px); }

.btn-hero--primary {
  background: var(--navy-500); color: white;
  box-shadow: 0 4px 20px rgba(26,58,92,.5);
}

.btn-hero--primary:hover { box-shadow: 0 12px 36px rgba(26,58,92,.6); }

.btn-hero--ghost {
  background: rgba(255,255,255,.06); color: var(--silver-300);
  border: 1px solid rgba(255,255,255,.14); backdrop-filter: blur(8px);
}

.btn-hero--ghost:hover { color: white; border-color: rgba(255,255,255,.3); }

.hero__scroll {
  position: absolute; bottom: 40px; left: 50%;
  transform: translateX(-50%);
  opacity: 0; animation: fadeIn 1s 1.4s ease forwards;
}

.hero__scroll-wheel {
  width: 24px; height: 38px;
  border: 2px solid rgba(255,255,255,.2); border-radius: 12px; position: relative;
}

.hero__scroll-wheel::after {
  content: ''; position: absolute;
  top: 6px; left: 50%; transform: translateX(-50%);
  width: 4px; height: 8px;
  background: rgba(255,255,255,.5); border-radius: 2px;
  animation: scroll-dot 2s ease-in-out infinite;
}

@keyframes scroll-dot {
  0%,100% { top: 6px; opacity: 1; }
  60%     { top: 18px; opacity: 0; }
}

/* ── Services ─────────────────────────────────── */
.services { background: var(--silver-100); padding: 120px 10vw 100px; }

.services__header { max-width: 560px; margin-bottom: 72px; }

.eyebrow {
  display: inline-block;
  font-size: .72rem; font-weight: 700;
  letter-spacing: .12em; text-transform: uppercase;
  color: var(--navy-600); margin-bottom: 16px;
}

.services__header h2 {
  font-size: clamp(2.25rem, 4vw, 3.25rem);
  font-weight: 800; line-height: 1.1;
  letter-spacing: -.025em; color: var(--navy-900);
}

.services__header h2 em {
  font-style: normal;
  background: linear-gradient(135deg, var(--navy-700) 0%, var(--navy-400) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

.cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

.card {
  position: relative;
  background: white; border-radius: 20px;
  padding: 40px 36px 36px;
  border: 1.5px solid var(--silver-200);
  box-shadow: 0 2px 8px rgba(13,31,51,.06);
  overflow: hidden; transform-style: preserve-3d;
