# ── Cloudflare Turnstile ───────────────────────────────────────────────────
# Get these from: https://dash.cloudflare.com → Turnstile
# Add your domain (k3creativeworks.com) and choose "Managed" challenge type.

PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ── Resend ─────────────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
# Also verify your domain at: https://resend.com/domains
# Add k3creativeworks.com and set the DNS records Resend provides.

RESEND_API_KEY=re_your_api_key_here
