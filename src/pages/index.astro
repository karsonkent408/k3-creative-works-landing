@media (max-width: 480px) {
  .hero__actions { flex-direction: column; }
  .hero__actions .btn-hero { width: 100%; justify-content: center; }
  .submit-btn { width: 100%; justify-content: center; }
}
</style>

<script>
// Footer year
const yr = document.getElementById('yr');
if (yr) yr.textContent = String(new Date().getFullYear());

// ── Custom cursor ─────────────────────────────
const cursorDot  = document.querySelector<HTMLElement>('.cursor__dot');
const cursorRing = document.querySelector<HTMLElement>('.cursor__ring');
let mouseX = 0, mouseY = 0, ringX = 0, ringY = 0;
const hasMouse = window.matchMedia('(hover: hover)').matches;

if (hasMouse && cursorDot && cursorRing) {
  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX; mouseY = e.clientY;
    cursorDot.style.left = mouseX + 'px';
    cursorDot.style.top  = mouseY + 'px';
  });

  const loopRing = () => {
    ringX += (mouseX - ringX) * 0.12;
    ringY += (mouseY - ringY) * 0.12;
    cursorRing.style.left = ringX + 'px';
    cursorRing.style.top  = ringY + 'px';
    requestAnimationFrame(loopRing);
  };
  loopRing();

  document.querySelectorAll('a, button, [data-magnetic]').forEach(el => {
    el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
    el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
  });

  document.addEventListener('mousedown', () => document.body.classList.add('cursor-click'));
  document.addEventListener('mouseup',   () => document.body.classList.remove('cursor-click'));
}

// ── Nav ───────────────────────────────────────
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 60);
}, { passive: true });

// ── Mobile nav ────────────────────────────────
const burger     = document.getElementById('burger');
const mobileMenu = document.getElementById('mobile-menu');

burger?.addEventListener('click', () => {
  const open = mobileMenu?.classList.toggle('open');
  burger.setAttribute('aria-expanded', open ? 'true' : 'false');
});

mobileMenu?.querySelectorAll('a').forEach(a =>
  a.addEventListener('click', () => {
    mobileMenu.classList.remove('open');
    burger?.setAttribute('aria-expanded', 'false');
  })
);

// ── Hero canvas — interactive particle mesh ────
(() => {
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  const ctx = canvas?.getContext('2d');
  if (!canvas || !ctx) return;

  let W = 0, H = 0;
  const mouse = { x: -9999, y: -9999 };
  const resize = () => { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; };
  window.addEventListener('resize', resize, { passive: true });
  resize();

  type Pt = { x: number; y: number; vx: number; vy: number; r: number; a: number };
  const N = 85;
  const pts: Pt[] = Array.from({ length: N }, () => ({
    x: Math.random() * W, y: Math.random() * H,
    vx: (Math.random() - .5) * .4, vy: (Math.random() - .5) * .4,
    r: Math.random() * 1.8 + .5, a: Math.random() * .5 + .15,
  }));

  const LINK = 140, PUSH_R = 180, PUSH_F = 60;

  canvas.addEventListener('mousemove', (e) => {
    const r = canvas.getBoundingClientRect();
    mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
  });
  canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

  const tick = () => {
    ctx.clearRect(0, 0, W, H);

    for (const p of pts) {
      const dx = p.x - mouse.x, dy = p.y - mouse.y;
      const d = Math.hypot(dx, dy);
      if (d < PUSH_R) { const f = (1 - d / PUSH_R) * PUSH_F * .018; p.vx += (dx / d) * f; p.vy += (dy / d) * f; }
      p.vx *= .985; p.vy *= .985;
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
      if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(122,170,212,${p.a})`; ctx.fill();
    }

    for (let i = 0; i < N; i++) {
      for (let j = i + 1; j < N; j++) {
        const d = Math.hypot(pts[i].x - pts[j].x, pts[i].y - pts[j].y);
        if (d < LINK) {
          ctx.beginPath(); ctx.moveTo(pts[i].x, pts[i].y); ctx.lineTo(pts[j].x, pts[j].y);
          ctx.strokeStyle = `rgba(74,124,181,${(1 - d / LINK) * .2})`;
          ctx.lineWidth = .8; ctx.stroke();
        }
      }
    }
    requestAnimationFrame(tick);
  };
  tick();
})();

// ── Hero glow follows mouse ────────────────────
const heroGlow = document.getElementById('hero-glow');
document.getElementById('hero')?.addEventListener('mousemove', (e) => {
  const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
  if (heroGlow) {
    heroGlow.style.left = (e.clientX - rect.left) + 'px';
    heroGlow.style.top  = (e.clientY - rect.top)  + 'px';
  }
});

// ── 3D card tilt ──────────────────────────────
document.querySelectorAll<HTMLElement>('[data-tilt]').forEach(card => {
  const MAX = 12;

  card.addEventListener('mousemove', (e) => {
    const r = card.getBoundingClientRect();
    const dx = (e.clientX - r.left - r.width  / 2) / (r.width  / 2);
    const dy = (e.clientY - r.top  - r.height / 2) / (r.height / 2);
    card.style.transform   = `perspective(800px) rotateX(${-dy * MAX}deg) rotateY(${dx * MAX}deg) scale3d(1.03,1.03,1.03)`;
    card.style.transition  = 'transform .05s linear, box-shadow .3s, border-color .3s';

    const shine = card.querySelector<HTMLElement>('.card__shine');
    if (shine) {
      shine.style.setProperty('--mx', ((e.clientX - r.left) / r.width  * 100) + '%');
      shine.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100) + '%');
    }
  });

  card.addEventListener('mouseleave', () => {
    card.style.transition = 'transform .5s cubic-bezier(.4,0,.2,1), box-shadow .3s, border-color .3s';
    card.style.transform  = 'perspective(800px) rotateX(0deg) rotateY(0deg) scale3d(1,1,1)';
  });
});

// ── Magnetic elements ─────────────────────────
document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach(el => {
  let animId = 0, tx = 0, ty = 0, cx = 0, cy = 0, rx = 0, ry = 0;

  el.addEventListener('mousemove', (e) => {
    const r = el.getBoundingClientRect();
    cx = r.left + r.width / 2; cy = r.top + r.height / 2;
    tx = (e.clientX - cx) * .35; ty = (e.clientY - cy) * .35;
  });

  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

  const loop = () => {
    rx = lerp(rx, tx, .18); ry = lerp(ry, ty, .18);
    el.style.transform = `translate(${rx}px, ${ry}px)`;
    animId = requestAnimationFrame(loop);
  };

  el.addEventListener('mouseenter', () => { cancelAnimationFrame(animId); rx = 0; ry = 0; loop(); });
  el.addEventListener('mouseleave', () => {
    tx = 0; ty = 0;
    setTimeout(() => { cancelAnimationFrame(animId); el.style.transform = ''; }, 350);
  });
});

// ── Scroll reveal ─────────────────────────────
const ro = new IntersectionObserver(
  (es) => es.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('in-view'); ro.unobserve(e.target); }
  }),
  { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
);

document.querySelectorAll('.js-reveal').forEach((el, i) => {
  (el as HTMLElement).style.transitionDelay = `${i * 0.08}s`;
  ro.observe(el);
});

// ── Hero right — isometric scene ─────────────
(() => {
  const canvas = document.getElementById('hero-scene') as HTMLCanvasElement | null;
  const ctx = canvas?.getContext('2d');
  if (!canvas || !ctx) return;

  let W = 0, H = 0;
  const mouse = { nx: 0, ny: 0 }; // normalised -1..1
  let smx = 0, smy = 0;           // smoothed mouse

  const resize = () => {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  };
  window.addEventListener('resize', resize, { passive: true });
  resize();

  // Mouse tracking (relative to whole window — more responsive)
  window.addEventListener('mousemove', (e) => {
    mouse.nx = (e.clientX / window.innerWidth)  * 2 - 1;
    mouse.ny = (e.clientY / window.innerHeight) * 2 - 1;
  });

  // ── Isometric cube helpers ──────────────────
  const C30 = Math.cos(Math.PI / 6); // ≈ 0.866
  const S30 = Math.sin(Math.PI / 6); // 0.5

  function isoVerts(cx: number, cy: number, s: number) {
    return {
      top:   [cx,        cy - s],
      tr:    [cx + s*C30, cy - s*S30],
      br:    [cx + s*C30, cy + s*S30],
      bot:   [cx,        cy + s],
      bl:    [cx - s*C30, cy + s*S30],
      tl:    [cx - s*C30, cy - s*S30],
      mid:   [cx,        cy],
    };
  }

  function drawCube(
    ctx: CanvasRenderingContext2D,
    cx: number, cy: number, s: number,
    alpha: number,
    topColor: string, rightColor: string, leftColor: string,
    glowColor?: string
  ) {
    const v = isoVerts(cx, cy, s);
    const path = (pts: number[][]) => {
      ctx.beginPath();
      ctx.moveTo(pts[0][0], pts[0][1]);
      for (let i = 1; i < pts.length; i++) ctx.lineTo(pts[i][0], pts[i][1]);
      ctx.closePath();
    };

    ctx.globalAlpha = alpha;

    // Optional glow
    if (glowColor) {
      ctx.shadowColor = glowColor;
      ctx.shadowBlur  = s * 0.6;
    }

    // Top face
    path([v.top, v.tr, v.mid, v.tl]);
    ctx.fillStyle = topColor;
    ctx.fill();

    // Right face
    path([v.tr, v.br, v.bot, v.mid]);
    ctx.fillStyle = rightColor;
    ctx.fill();

    // Left face
    path([v.tl, v.mid, v.bot, v.bl]);
    ctx.fillStyle = leftColor;
    ctx.fill();

    ctx.shadowBlur = 0;

    // Edges
    ctx.strokeStyle = `rgba(122,170,212,${alpha * 0.35})`;
    ctx.lineWidth = 0.8;

    // Top outline
    path([v.top, v.tr, v.mid, v.tl]);
    ctx.stroke();

    // Right outline
    path([v.tr, v.br, v.bot, v.mid]);
    ctx.stroke();

    // Left outline
    path([v.tl, v.mid, v.bot, v.bl]);
    ctx.stroke();

    ctx.globalAlpha = 1;
  }

  // ── K3 text on main cube ────────────────────
  function drawK3(ctx: CanvasRenderingContext2D, cx: number, cy: number, s: number, alpha: number) {
    // Project text onto the right face of the cube
    // Right face center ≈ (cx + s*C30*0.5, cy + s*0.25)
    const tx = cx + s * C30 * 0.52;
    const ty = cy + s * 0.1;

    ctx.save();
    ctx.globalAlpha = alpha * 0.7;

    // Skew to match the right face angle
    ctx.translate(tx, ty);
    ctx.transform(1, S30 * 0.6, 0, 1, 0, 0);

    ctx.font = `700 ${s * 0.42}px "Inter", sans-serif`;
    ctx.fillStyle = 'rgba(255,255,255,0.55)';
    ctx.letterSpacing = '-1px';
    ctx.fillText('K3', -s * 0.28, s * 0.14);

    ctx.restore();
  }

  // ── Scene config ────────────────────────────
  // Each object: base x/y as fraction of W/H, size, parallax depth, float phase/speed
  type Cube = {
    bx: number; by: number; size: number; depth: number;
    phase: number; floatSpeed: number; floatAmp: number;
    topC: string; rightC: string; leftC: string;
    glow?: string; main?: boolean;
  };

  const cubes: Cube[] = [
    // Main large cube — centre
    { bx:.48, by:.48, size:88, depth:.18, phase:0,   floatSpeed:.0008, floatAmp:10,
      topC:'#214b75', rightC:'#1a3a5c', leftC:'#0d1f33', glow:'rgba(74,124,181,.6)', main:true },
    // Top-right satellite
    { bx:.80, by:.22, size:44, depth:.10, phase:1.2, floatSpeed:.0006, floatAmp:8,
      topC:'#1a3a5c', rightC:'#122944', leftC:'#0a1c2e' },
    // Bottom-left satellite
    { bx:.18, by:.72, size:36, depth:.07, phase:2.5, floatSpeed:.0007, floatAmp:6,
      topC:'#182e44', rightC:'#101f30', leftC:'#0a1824' },
    // Top-left small
    { bx:.22, by:.28, size:26, depth:.05, phase:.8,  floatSpeed:.0009, floatAmp:5,
      topC:'#1d3a58', rightC:'#152b40', leftC:'#0c1e2e' },
    // Bottom-right small
    { bx:.78, by:.74, size:30, depth:.06, phase:3.8, floatSpeed:.0008, floatAmp:7,
      topC:'#1a3251', rightC:'#12263c', leftC:'#0b1b2a' },
    // Far top tiny
    { bx:.62, by:.12, size:18, depth:.03, phase:1.8, floatSpeed:.001,  floatAmp:4,
      topC:'#19304a', rightC:'#112236', leftC:'#0b1824' },
    // Far bottom tiny
    { bx:.35, by:.86, size:14, depth:.02, phase:4.2, floatSpeed:.0012, floatAmp:3,
      topC:'#162c43', rightC:'#0f2033', leftC:'#091a28' },
  ];

  // Connecting lines between main cube and satellites
  const connections = [
    [0, 1], [0, 2], [0, 3], [0, 4], [1, 5],
  ];

  // ── Animation loop ───────────────────────────
  let t = 0;

  const tick = () => {
    t++;
    ctx.clearRect(0, 0, W, H);

    // Smooth mouse
    smx += (mouse.nx - smx) * 0.06;
    smy += (mouse.ny - smy) * 0.06;

    // Compute current positions — pure mouse parallax, no float
    const positions = cubes.map((c) => {
      const cx = c.bx * W + smx * c.depth * W * 0.4;
      const cy = c.by * H + smy * c.depth * H * 0.4;
      return { cx, cy };
    });

    // Draw connection lines first (behind cubes)
    ctx.save();
    for (const [ai, bi] of connections) {
      const a = positions[ai], b = positions[bi];
      const dist = Math.hypot(b.cx - a.cx, b.cy - a.cy);
      const alpha = Math.max(0, 1 - dist / (W * 0.6)) * 0.18;
      const grad = ctx.createLinearGradient(a.cx, a.cy, b.cx, b.cy);
      grad.addColorStop(0, `rgba(74,124,181,${alpha})`);
      grad.addColorStop(1, `rgba(74,124,181,0)`);
      ctx.beginPath();
      ctx.moveTo(a.cx, a.cy);
      ctx.lineTo(b.cx, b.cy);
      ctx.strokeStyle = grad;
      ctx.lineWidth = 1;
      ctx.stroke();
    }
    ctx.restore();

    // Draw cubes (sorted by size, largest last = on top)
    const order = cubes.map((c, i) => ({ c, i }))
      .sort((a, b) => a.c.size - b.c.size);

    for (const { c, i } of order) {
      const { cx, cy } = positions[i];
      // Alpha based on size — smaller = more transparent
      const alpha = 0.3 + (c.size / 90) * 0.7;
      drawCube(ctx, cx, cy, c.size, alpha, c.topC, c.rightC, c.leftC, c.glow);
      if (c.main) drawK3(ctx, cx, cy, c.size, 1);
    }

    // Pulsing ring on main cube
    const main = positions[0];
    const pulse = (Math.sin(t * 0.025) + 1) / 2; // 0..1
    const ringR = cubes[0].size * (1.3 + pulse * 0.3);
    ctx.beginPath();
    ctx.arc(main.cx, main.cy, ringR, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(74,124,181,${0.06 + pulse * 0.06})`;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Second outer ring
    const ringR2 = cubes[0].size * (1.8 + pulse * 0.2);
    ctx.beginPath();
    ctx.arc(main.cx, main.cy, ringR2, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(74,124,181,${0.03 + pulse * 0.03})`;
    ctx.lineWidth = .5;
    ctx.stroke();

    requestAnimationFrame(tick);
  };

  tick();

  // ── Parallax floating labels ──────────────────
  document.querySelectorAll<HTMLElement>('.hero__label').forEach((el) => {
    const depth = parseFloat(el.dataset.depth ?? '0.05');
    const baseLeft = parseFloat(el.style.left);
    const baseTop  = parseFloat(el.style.top);

    const updateLabel = () => {
      const ox = smx * depth * 100;
      const oy = smy * depth * 100;
      el.style.transform = `translate(${ox}%, ${oy}%)`;
      requestAnimationFrame(updateLabel);
    };
    updateLabel();
  });
})();

// ── Contact form ──────────────────────────────
const form      = document.getElementById('contact-form') as HTMLFormElement | null;
const success   = document.getElementById('form-success');
const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
const errorBanner = document.getElementById('form-error');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();

  // Client-side validation
  let valid = true;
  form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[required]').forEach(f => {
    const ok = f.value.trim() !== '';
    f.style.borderBottomColor = ok ? '' : '#e55';
    if (!ok) valid = false;
  });
  if (!valid) return;

  // Hide any previous error
  if (errorBanner) { errorBanner.hidden = true; errorBanner.textContent = ''; }

  submitBtn?.classList.add('loading');
  if (submitBtn) submitBtn.disabled = true;

  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      body: new FormData(form),
    });

    const data = await res.json() as { ok?: boolean; error?: string };

    if (res.ok && data.ok) {
      form.style.display = 'none';
      if (success) {
        success.hidden = false;
        success.classList.add('visible');
      }
    } else {
      throw new Error(data.error ?? 'Something went wrong. Please try again.');
    }
  } catch (err) {
    const msg = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
    if (errorBanner) {
      errorBanner.textContent = msg;
      errorBanner.hidden = false;
    }
    submitBtn?.classList.remove('loading');
    if (submitBtn) submitBtn.disabled = false;

    // Reset Turnstile so user can retry
    if (typeof (window as any).turnstile !== 'undefined') {
      (window as any).turnstile.reset();
    }
  }
});
</script>
